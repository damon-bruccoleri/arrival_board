# Copy to arrival_board.env and edit values:
#   cp -n arrival_board.env.example arrival_board.env

MTA_KEY=Insert MTA key here
STOP_ID=501627
POLL_SECONDS=10

# Fonts: optional overrides. Defaults: Noto (body/symbols), then DejaVu; title = TITLE_FONT_PATH or $HOME/.../tools/fonts/Smythe-Regular.ttf.
# FONT_PATH=/usr/share/fonts/truetype/noto/NotoSans-Regular.ttf
# TITLE_FONT_PATH=$HOME/arrival_board/tools/fonts/Smythe-Regular.ttf
# SYMBOL_FONT_PATH=/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf

# Weather: STOP_LAT / STOP_LON for this stop, or NYC default if unset.
STOP_LAT=40.740
STOP_LON=-73.756

# Optional: background music and flip use single defaults under $HOME/arrival_board/tools/ (MUSIC_FILE, SOUND_FLIP not used).
# Only set APLAY_DEVICE=hdmi:... if you run as the user that owns the device (direct ALSA; flip pauses music).
# MUSIC_DURATION_SEC=23   (total cycle 23s; gap = 23 - actual file length)
# MUSIC_FILE_SEC=21       (actual file length in seconds; set if WAV header is wrong)
# Troubleshooting: AUDIO_DEBUG=1 logs paths and flip triggers to stderr.

# Optional: GTFS static for scheduled tiles (Express routes at stop 501627 need MTABC feed)
# Default: MTABC (MTA Bus Company) for QM8, QM5, QM35, etc. at Springfield Blvd/73 Av
# GTFS_BUS_URL=https://rrgtfsfeeds.s3.amazonaws.com/gtfs_busco.zip
# GTFS_CACHE_PATH=$HOME/arrival_board/gtfs_bus_cache.zip
# Queens-only feed (no QM8 at 501627): https://rrgtfsfeeds.s3.amazonaws.com/gtfs_q.zip
