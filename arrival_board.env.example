# Copy to arrival_board.env and edit values:
#   cp -n arrival_board.env.example arrival_board.env

MTA_KEY=Insert MTA key here
STOP_ID=501627
POLL_SECONDS=10

# Fonts: optional overrides. No fallbacks—if a font is missing, the app exits with a clear message.
# Body (and Bold variant in same dir): FONT_PATH. Title: TITLE_FONT_PATH (optional; if set, must exist).
# Symbol: SYMBOL_FONT_PATH. Emoji (moon/weather): EMOJI_FONT_PATH.
# Defaults: Noto Sans (body), Noto Symbols2 (symbol), Noto Color Emoji (emoji). Install: fonts-noto-core, fonts-noto-color-emoji.
# FONT_PATH=/usr/share/fonts/truetype/noto/NotoSans-Regular.ttf
# TITLE_FONT_PATH=$HOME/arrival_board/tools/fonts/Smythe-Regular.ttf
# SYMBOL_FONT_PATH=/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf
# EMOJI_FONT_PATH=/usr/share/fonts/truetype/noto/NotoColorEmoji.ttf

# Weather: STOP_LAT / STOP_LON for this stop, or NYC default if unset.
STOP_LAT=40.740
STOP_LON=-73.756

# Optional: background music and flip use single defaults under $HOME/arrival_board/tools/ (MUSIC_FILE, SOUND_FLIP not used).
#
# Pi Zero / kiosk: direct ALSA often reduces stutter vs Pulse+resampling. List devices: aplay -L
# Example HDMI (adjust CARD name to match `aplay -L`): plughw:CARD=vc4hdmi0,DEV=0
# Verify: bash tools/verify_aplay_device.sh 'plughw:CARD=vc4hdmi0,DEV=0'
# APLAY_DEVICE=plughw:CARD=vc4hdmi0,DEV=0
#
# With APLAY_DEVICE set, music and flip use aplay (no PipeWire mix). Use 44.1 kHz or 48 kHz 16-bit PCM WAVs
# so the app can call paplay/aplay directly without sox (see AUDIO_FORCE_SOX).
#
# MUSIC_DURATION_SEC=23   (total cycle 23s; gap = 23 - actual file length)
# MUSIC_FILE_SEC=21       (actual file length in seconds; set if WAV header is wrong)
# AUDIO_DEBUG=1           (optional; default off — only logs when set to 1)
# AUDIO_FORCE_SOX=1       (force sox for software gain; CPU-heavy on Pi Zero)

# Lite / kiosk: SDL_VIDEODRIVER=kmsdrm is often set by tools/setup_pi.sh when creating arrival_board.env
# SDL_RENDER_SCALE_QUALITY=linear  (optional; default is nearest for Pi performance)

# Optional: GTFS static for scheduled tiles (Express routes at stop 501627 need MTABC feed)
# Default: MTABC (MTA Bus Company) for QM8, QM5, QM35, etc. at Springfield Blvd/73 Av
# GTFS_BUS_URL=https://rrgtfsfeeds.s3.amazonaws.com/gtfs_busco.zip
# GTFS_CACHE_PATH=$HOME/arrival_board/gtfs_bus_cache.zip
# Queens-only feed (no QM8 at 501627): https://rrgtfsfeeds.s3.amazonaws.com/gtfs_q.zip

# Phone setup mode: GPIO13 is active-low with an internal pull-up. Pressing the
# switch to ground starts a temporary hotspot and setup page.
# CONFIG_AP_SSID=ArrivalBoard
# CONFIG_AP_ADDR=192.168.4.1
# CONFIG_WIFI_IFACE=wlan0
